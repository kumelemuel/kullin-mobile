# Kullin local development environment
# Copy to .env and fill in secrets. Never commit .env.

# API
HOST=0.0.0.0
PORT=3000
KULLIN_API_TOKEN=change-me-to-a-long-random-token

# Actual Budget (API-only secrets — never configure these in the mobile app)
ACTUAL_SERVER_URL=http://actual:5006
ACTUAL_PASSWORD=
ACTUAL_BUDGET_ID=
ACTUAL_DATA_DIR=/data/actual-cache
ACTUAL_PORT=5006
